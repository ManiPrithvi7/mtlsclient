# Copy to .env (optional). The client also loads ../../statsmqtt/.env when present — use that for MQTT_* secrets.
# Recommended run mode:
# - Live backend mode: AUTO_PROVISION=0 npm run dev

# --- Provisioning (first run when USE_CRT_DIR=1 and device cert is missing) ---
# Onboarding (separate step, not this client): POST /api/v1/onboarding with Authorization: Bearer <user auth JWT>
#   + device_id → returns provisioning JWT.
# sign-csr (this client): only PROVISIONING_TOKEN + CSR. Default: Authorization: Bearer <provisioning JWT>, body { "csr": "..." }.
# Response is flat JSON: certificate (device PEM), ca_certificate (root PEM). Provisioning JWT is one-time after success — re-onboard for a new token.
# TOKEN_EXPIRED: get a new provisioning token from /onboarding. TOKEN_ALREADY_USED: same (or prior run succeeded but files were not saved).
# Optional: PROVISIONING_TOKEN_IN_BODY=1 → body { "csr", "provisioning_token" }, no Authorization header.
# PROVISIONING_SERVER_URL=https://your-api.example.com
# PROVISIONING_TOKEN=<provisioning JWT from onboarding>
# DEVICE_ID=ADMIN-1
# (Or ESP32-132ABC — CN becomes PROOF-{DEVICE_ID}. If you already use PROOF-xxx, it will not be doubled.)
# CERT_CN_PREFIX=PROOF

# Option A — full URL
# MQTT_URL=mqtts://your-instance.ala.dedicated.aws.emqxcloud.com:8883

# Option B — same variable names as statsmqtt .env
# MQTT_BROKER=your-instance.ala.dedicated.aws.emqxcloud.com
MQTT_PORT=8883

# Required for EMQX **built-in** username/password auth (connack 4 if wrong). Copy from statsmqtt/.env.
# MQTT_USERNAME=proof
# MQTT_PASSWORD=your_emqx_password

# Leave unset or 0 for typical EMQX Cloud. Setting 1 sends CONNECT username = cert CN with no password,
# which usually causes connack code 4 unless the broker is configured for CN-only X.509 auth.
# MQTT_PEER_CN_AS_MQTT_USERNAME=0

# connack 5 with mqttAuth=no: either add MQTT_USERNAME/PASSWORD above, or configure EMQX Authentication → X.509 with your device CA PEM.

# Broker TLS trust: MQTT_BROKER_CA or src/certs/broker-ca.crt (default CRT_DIR is src/certs).
# The broker’s *server* cert must chain to that trusted root. If NanoMQ uses another issuer than provisioning, put the broker’s issuing CA PEM in broker-ca.crt or MQTT_BROKER_CA — do not assume they match.
# Optional: force system trust only (ignore CRT_DIR/broker-ca.crt)
# MQTT_BROKER_CA=
